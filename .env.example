# NPPES MCP Server Environment Variables
# Copy this to .env and fill in your values

# Redis (Upstash) - REQUIRED for production
REDIS_URL=redis://localhost:6379
# Or for Upstash:
# REDIS_URL=https://your-upstash-url.upstash.io

# Cache settings
CACHE_TTL_SECONDS=3600
CACHE_KEY_PREFIX=nppes

# NPPES API (optional overrides)
# NPPES_API_URL=https://npiregistry.cms.hhs.gov/api
REQUEST_TIMEOUT_SECONDS=30

# Taxonomy CSV (optional - pre-bundled in Docker)
# TAXONOMY_CSV_PATH=/app/app/rag/taxonomy.csv

# Logging
LOG_LEVEL=INFO
